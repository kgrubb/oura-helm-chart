    {
      "type": "table",
      "title": "Recent workouts",
      "id": 26,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 15
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "__OURA_DS__"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT to_char(day, 'Mon FMDD') AS \"Date\",\n  initcap(replace(coalesce(nullif(activity, ''), nullif(label, ''), 'Workout'), '_', ' ')) AS \"Activity\",\n  initcap(coalesce(intensity, '')) AS \"Intensity\",\n  round(calories::numeric) AS \"kcal\",\n  CASE WHEN distance IS NOT NULL THEN round((distance / 1000.0)::numeric, 1) END AS \"km\"\nFROM workout\nORDER BY start_datetime DESC NULLS LAST\nLIMIT 20"
        }
      ],
      "options": {
        "showHeader": true
      },
      "description": "Latest workouts recorded by your ring."
    },
    {
      "type": "stat",
      "title": "Resilience",
      "description": "How well you're bouncing back from stress over time.\n\nLimited \u00b7 Adequate \u00b7 Solid \u00b7 Strong",
      "id": 27,
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 15
      },

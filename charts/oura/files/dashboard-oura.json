    {
      "type": "timeseries",
      "title": "Activity zone time (hours)",
      "id": 25,
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 8
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "__OURA_DS__"
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT day::timestamp AS time, sedentary_time/3600.0 AS \"Sedentary\",\nlow_activity_time/3600.0 AS \"Low\", medium_activity_time/3600.0 AS \"Medium\",\nhigh_activity_time/3600.0 AS \"High\"\nFROM daily_activity WHERE day BETWEEN ($__timeFrom()::date) AND ($__timeTo()::date) ORDER BY 1"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "custom": {
            "fillOpacity": 20,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      }
    },
    {
      "type": "table",
      "title": "Recent workouts",
      "id": 26,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "__OURA_DS__"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT to_char(day, 'Mon FMDD') AS \"Date\",\n  initcap(replace(coalesce(nullif(activity, ''), nullif(label, ''), 'Workout'), '_', ' ')) AS \"Activity\",\n  initcap(coalesce(intensity, '')) AS \"Intensity\",\n  round(calories::numeric) AS \"kcal\",\n  CASE WHEN distance IS NOT NULL THEN round((distance / 1000.0)::numeric, 1) END AS \"km\"\nFROM workout\nORDER BY start_datetime DESC NULLS LAST\nLIMIT 20"
        }
      ],
      "options": {
        "showHeader": true
      }
    },
    {
      "type": "stat",

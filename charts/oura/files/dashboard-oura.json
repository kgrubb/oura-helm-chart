    {
      "type": "timeseries",
      "title": "Time by activity level",
      "id": 25,
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 10
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "__OURA_DS__"
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT day::timestamp AS time, sedentary_time/3600.0 AS \"Sedentary\",\nlow_activity_time/3600.0 AS \"Low\", medium_activity_time/3600.0 AS \"Medium\",\nhigh_activity_time/3600.0 AS \"High\"\nFROM daily_activity WHERE day BETWEEN ($__timeFrom()::date) AND ($__timeTo()::date) ORDER BY 1"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "custom": {
            "fillOpacity": 20,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "description": "Hours spent sedentary or in low, medium, and high activity."
    },
    {
      "type": "row",
      "title": "Recovery and fitness",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "collapsed": false,
      "panels": [],
      "id": 32

        "type": "grafana-postgresql-datasource",
        "uid": "__OURA_DS__"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT CASE lower(level)\n  WHEN 'limited' THEN 0 WHEN 'adequate' THEN 1\n  WHEN 'solid' THEN 2 WHEN 'strong' THEN 3 ELSE -1 END AS \"Resilience\"\nFROM daily_resilience ORDER BY day DESC LIMIT 1"
        }
      ],
      "fieldConfig": {
        "defaults": {

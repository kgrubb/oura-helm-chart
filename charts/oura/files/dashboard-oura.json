      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT average_hrv AS \"HRV\" FROM sleep_period\nWHERE type = 'long_sleep' OR type IS NULL ORDER BY bedtime_end DESC NULLS LAST LIMIT 1"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"

      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT CASE lower(day_summary)\n  WHEN 'restored' THEN 0 WHEN 'normal' THEN 1\n  WHEN 'stressful' THEN 2 ELSE -1 END AS \"Stress\"\nFROM daily_stress ORDER BY day DESC LIMIT 1"
        }

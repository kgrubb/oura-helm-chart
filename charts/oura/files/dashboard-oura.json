    {
      "type": "table",
      "title": "Symptom history",
      "id": 21,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "__OURA_DS__"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT to_char(day, 'Mon FMDD') AS \"Day\",\n  CASE level\n    WHEN 'none' THEN 'no signs'\n    WHEN 'minor' THEN 'Minor Signs'\n    WHEN 'major' THEN 'Major signs'\n    ELSE 'n/a'\n  END AS \"Status\"\nFROM symptom_radar_daily\nORDER BY day DESC\nLIMIT 14"
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "filterable": false
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Status"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "no signs": {
                        "color": "green",
                        "index": 0
                      },
                      "Minor Signs": {
                        "color": "yellow",
                        "index": 1
                      },
                      "Major signs": {
                        "color": "red",
                        "index": 2
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              }
            ]
          }
        ]
      },
      "description": "Recent Symptom Radar results by day."
    },
    {
      "type": "bargauge",
      "title": "Readiness factors",
      "id": 22,
      "description": "The pieces that make up today's Readiness score (each 0-100).",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 6
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "__OURA_DS__"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  (contributors->>'body_temperature')::float AS \"Temperature\",\n  (contributors->>'resting_heart_rate')::float AS \"Resting HR\",\n  (contributors->>'hrv_balance')::float AS \"HRV\",\n  (contributors->>'sleep_balance')::float AS \"Sleep\",\n  (contributors->>'sleep_regularity')::float AS \"Regularity\",\n  (contributors->>'previous_night')::float AS \"Last night\",\n  (contributors->>'previous_day_activity')::float AS \"Yesterday\",\n  (contributors->>'activity_balance')::float AS \"Activity\",\n  (contributors->>'recovery_index')::float AS \"Recovery\"\nFROM daily_readiness\nWHERE day = (SELECT max(day) FROM daily_readiness)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 60
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "green",
                "value": 85
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "/.*/"
        },
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": true,
        "sizing": "manual",
        "minVizHeight": 16,
        "colorMode": "background"
      }
    },
    {

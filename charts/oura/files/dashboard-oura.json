          "refId": "A",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT day::timestamp AS time, deep_sleep_duration/3600.0 AS \"Deep\", rem_sleep_duration/3600.0 AS \"REM\", light_sleep_duration/3600.0 AS \"Light\", awake_time/3600.0 AS \"Awake\" FROM sleep_period WHERE day BETWEEN ($__timeFrom()::date) AND ($__timeTo()::date) AND (type = 'long_sleep' OR type IS NULL) ORDER BY 1"

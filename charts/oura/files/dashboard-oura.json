    {
      "type": "stat",
      "title": "Symptom Radar",
      "id": 20,
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "__OURA_DS__"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT CASE level WHEN 'none' THEN 0 WHEN 'minor' THEN 1 WHEN 'major' THEN 2 ELSE -1 END AS \"Radar\"\nFROM symptom_radar_daily ORDER BY day DESC LIMIT 1"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "no symptoms", "color": "green" },
                "1": { "text": "Minor Signs", "color": "orange" },
                "2": { "text": "Major signs", "color": "red" },
                "-1": { "text": "—", "color": "text" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },

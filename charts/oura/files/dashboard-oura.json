                "color": "purple",
                "value": null
              }
            ]
          }
        }
      }
    },
    {
      "type": "table",
      "title": "Radar Details",
      "id": 21,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "__OURA_DS__"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT to_char(day, 'Mon FMDD') AS \"Day\",\n  CASE level\n    WHEN 'none' THEN 'no symptoms'\n    WHEN 'minor' THEN 'Minor Signs'\n    WHEN 'major' THEN 'Major signs'\n    ELSE '—'\n  END AS \"Status\"\nFROM symptom_radar_daily\nORDER BY day DESC\nLIMIT 14"
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "filterable": false
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Status"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "no symptoms": {
                        "color": "green",
                        "index": 0
                      },
                      "Minor Signs": {
                        "color": "orange",
                        "index": 1
                      },
                      "Major signs": {
                        "color": "red",
                        "index": 2
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "type": "bargauge",
      "title": "Readiness factors",
      "id": 22,
      "description": "How each factor scored in today's readiness (0–100). This is Oura's own breakdown of the readiness score.",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 4
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "__OURA_DS__"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT CASE key\n  WHEN 'hrv_balance' THEN 'HRV'\n  WHEN 'sleep_balance' THEN 'Sleep'\n  WHEN 'previous_night' THEN 'Last night'\n  WHEN 'recovery_index' THEN 'Recovery'\n  WHEN 'activity_balance' THEN 'Activity'\n  WHEN 'body_temperature' THEN 'Temperature'\n  WHEN 'sleep_regularity' THEN 'Regularity'\n  WHEN 'resting_heart_rate' THEN 'Resting HR'\n  WHEN 'previous_day_activity' THEN 'Yesterday'\n  ELSE initcap(replace(key, '_', ' '))\nEND AS \"Factor\",\nvalue::float AS \"Score\"\nFROM daily_readiness, jsonb_each_text(contributors)\nWHERE day = (SELECT max(day) FROM daily_readiness)\nORDER BY 2 DESC"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 70
              },
              {
                "color": "green",
                "value": 85
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "displayMode": "gradient",
        "orientation": "horizontal"
      }
    },
